<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DC Miranda | Resume</title>
    <style>
      :root {
        --bg: #07111f;
        --bg-soft: #0f1d31;
        --card: rgba(10, 19, 33, 0.78);
        --text: #f3f7ff;
        --muted: #aebfd8;
        --accent: #5ee7c7;
        --accent-2: #86a8ff;
        --border: rgba(255, 255, 255, 0.12);
        --shadow: 0 20px 50px rgba(0, 0, 0, 0.28);
        --scroll-progress: 0;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: "Inter", "Segoe UI", Roboto, Arial, sans-serif;
        color: var(--text);
        background: radial-gradient(circle at top left, #13243d 0%, var(--bg) 45%, #050911 100%);
        line-height: 1.6;
        overflow-x: hidden;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
      }

      body::before {
        background: linear-gradient(120deg, rgba(94,231,199,0.15), rgba(134,168,255,0.08));
        transform: translate3d(0, calc(var(--scroll-progress) * -40px), 0);
        filter: blur(25px);
      }

      body::after {
        background-image: radial-gradient(circle, rgba(255,255,255,0.12) 1px, transparent 1px);
        background-size: 20px 20px;
        opacity: 0.12;
        transform: translate3d(0, calc(var(--scroll-progress) * 40px), 0);
      }

      .page {
        position: relative;
        z-index: 1;
        max-width: 1160px;
        margin: 0 auto;
        padding: 36px 24px 80px;
      }

      .hero {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--border);
        background: linear-gradient(135deg, rgba(10,20,35,0.92), rgba(8,15,26,0.8));
        border-radius: 30px;
        padding: 44px;
        box-shadow: var(--shadow);
        margin-bottom: 24px;
      }

      .hero::before,
      .hero::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        filter: blur(4px);
        opacity: 0.6;
      }

      .hero::before {
        width: 320px;
        height: 320px;
        background: radial-gradient(circle, rgba(94,231,199,0.24), transparent 70%);
        top: -80px;
        right: -80px;
        transform: translate3d(0, calc(var(--scroll-progress) * -30px), 0);
      }

      .hero::after {
        width: 220px;
        height: 220px;
        background: radial-gradient(circle, rgba(134,168,255,0.18), transparent 70%);
        bottom: -60px;
        left: -50px;
        transform: translate3d(0, calc(var(--scroll-progress) * 35px), 0);
      }

      .hero-content {
        position: relative;
        z-index: 1;
      }

      .eyebrow {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        font-size: 0.78rem;
        color: var(--accent);
        margin-bottom: 10px;
      }

      h1 {
        font-size: clamp(2rem, 4vw, 3rem);
        margin: 0 0 10px;
      }

      .role {
        font-size: 1.08rem;
        color: var(--accent-2);
        font-weight: 600;
        margin-bottom: 16px;
      }

      .hero p {
        max-width: 780px;
        color: var(--muted);
        font-size: 1rem;
        margin: 0 0 20px;
      }

      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 16px;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 9px 14px;
        border: 1px solid rgba(94,231,199,0.3);
        border-radius: 999px;
        background: rgba(94,231,199,0.08);
        color: var(--text);
        font-size: 0.95rem;
      }

      .section-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 28px;
        box-shadow: var(--shadow);
        margin-bottom: 20px;
        backdrop-filter: blur(10px);
        transform: translate3d(0, calc(var(--scroll-progress) * 18px), 0);
      }

      h2 {
        font-size: 1.2rem;
        margin-top: 0;
        margin-bottom: 12px;
        color: var(--accent);
      }

      .summary {
        color: var(--muted);
        font-size: 1rem;
      }

      .grid {
        display: grid;
        gap: 18px;
      }

      .experience-item {
        padding: 16px 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }

      .experience-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      .experience-title {
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 4px;
      }

      .meta {
        color: var(--accent-2);
        font-size: 0.95rem;
        margin-bottom: 8px;
      }

      ul {
        margin: 0;
        padding-left: 20px;
        color: var(--muted);
      }

      li + li { margin-top: 7px; }

      .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 14px;
      }

      .skill-box {
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        background: rgba(255,255,255,0.03);
        padding: 14px 14px 12px;
      }

      .skill-box strong {
        display: block;
        margin-bottom: 8px;
        color: var(--text);
      }

      .skill-box span {
        color: var(--muted);
        font-size: 0.95rem;
      }

      .links {
        display: grid;
        gap: 12px;
      }

      .link-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-radius: 14px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        text-decoration: none;
        color: var(--text);
      }

      .link-card:hover {
        border-color: rgba(94,231,199,0.35);
        transform: translateY(-2px);
      }

      .contact-block {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 10px;
      }

      .contact-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        color: var(--text);
        text-decoration: none;
      }

      .contact-pill:hover {
        border-color: rgba(94,231,199,0.3);
      }

      a { color: var(--accent); }

      @media (max-width: 700px) {
        .hero { padding: 28px; }
        .section-card { padding: 22px; }
        .link-card { flex-direction: column; align-items: flex-start; }
      }
    </style>
  </head>
